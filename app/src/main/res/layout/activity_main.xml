<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AOD Suite"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Always On Display via Shizuku"
            android:textSize="13sp"
            android:layout_marginBottom="16dp"/>

        <!-- Shizuku card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvShizukuStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking Shizuku…"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRequestShizuku"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Connect Shizuku"
                    android:layout_marginBottom="4dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSetup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⚙️ Setup (Grant Permissions)"
                    android:visibility="gone"/>

                <ProgressBar
                    android:id="@+id/progressBar"
                    style="?android:attr/progressBarStyleHorizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:indeterminate="true"
                    android:visibility="gone"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AOD toggle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌙 Always On Display"
                    android:textSize="15sp"
                    android:textStyle="bold"/>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAod"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Brightness -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="☀️ Min Brightness"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <TextView
                        android:id="@+id/tvBrightnessValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20%"
                        android:textSize="14sp"/>
                </LinearLayout>
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderBrightness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:stepSize="1"
                    android:value="20"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyBrightness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Apply Brightness"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Gestures -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="👆 Tap to wake"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchTap"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🤚 Raise to wake"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchRaise"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Night mode -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🌡️ Night Mode"
                        android:textSize="15sp"
                        android:textStyle="bold"/>
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNightMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderNightTemp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1000"
                    android:valueTo="6500"
                    android:stepSize="100"
                    android:value="3200"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AOD Timeout -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⏱️ AOD Timeout (seconds, 0=never)"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderTimeout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="300"
                    android:stepSize="10"
                    android:value="0"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Blurred wallpaper -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            android:layout_marginBottom="12dp">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🖼️ Blurred AOD Wallpaper"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.slider.Slider
                    android:id="@+id/sliderBlur"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="1"
                    android:valueTo="25"
                    android:stepSize="1"
                    android:value="12"
                    android:layout_marginBottom="8dp"/>
                <TextView
                    android:id="@+id/tvBlurValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Radius: 12"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnPickImage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pick Image"
                    android:layout_marginBottom="4dp"/>
                <TextView
                    android:id="@+id/tvImageName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No image selected"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnApplyWallpaper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Apply Blurred Wallpaper"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Status + log -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Connect Shizuku → tap Setup → done"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDump"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dump Settings"
            android:layout_marginBottom="4dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnClearLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Clear Log"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/tvLog"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
